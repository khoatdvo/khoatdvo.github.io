<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.homemedia" name="Home Media" version="0.4.8" provider-name="khoatdvo">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Home media hub: Fshare favorites and MotPhim</summary>
            <description lang="en_GB">A Kodi video add-on with multiple media sources. Fshare Favorites lists your Fshare.vn bookmarks for streaming (enter your email/password in settings). MotPhim browses motphimz.ac — sections, genres, and search — and streams films directly.</description>
            <platform>all</platform>
            <license>Apache-2.0</license>
            <source>https://github.com/khoatdvo/home-media</source>
            <assets>
                <icon>resources/icon.png</icon>
                <fanart>resources/fanart.png</fanart>
            </assets>
            <news>v0.4.8 - Fshare: retry the flaky nginx 400 on login/API so favorites stop failing.</news>
        </extension>
    </addon>
    <addon id="plugin.video.vietmediaF2" name="VietmediaF 2" version="11.37.6" provider-name="xxVNxx">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
            <import addon="script.module.six" />
            <import addon="script.module.requests" />
            <import addon="script.module.beautifulsoup4" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="default.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.service" library="autorun.py" />
        <extension point="xbmc.addon.metadata">
            <reuselanguageinvoker>true</reuselanguageinvoker>
            <summary lang="en">VietmediaF 2 for Kodi 21</summary>
            <description lang="en">Vietmediaf is an addon that aggregates Fshare links shared on the Internet.</description>
            <description lang="vi">VietmediaF 2 - Addon tổng hợp link fshare được chia sẻ trên Internet.</description>
            <disclaimer lang="en">
            Content is retrieved from the Internet and uploaded by users. VietmediaF is not responsible for the content displayed within the addon.
        </disclaimer>
            <disclaimer lang="vi">Nội dung lấy trên mạng và do người dùng tự upload lên. VietmediaF không chịu trách nhiệm về nội dung hiển thị bên trong addon.
        </disclaimer>
            <platform>all</platform>
            <assets>
                <icon>icon.png</icon>
            </assets>
        </extension>
    </addon>
    <addon id="repository.khoatdvo" name="Khoa's Kodi Repository" version="1.0.0" provider-name="khoatdvo">
        <extension point="xbmc.addon.repository" name="Khoa's Kodi Repository">
            <dir>
                <info compressed="false">https://khoatdvo.github.io/kodirepo/addons.xml</info>
                <checksum>https://khoatdvo.github.io/kodirepo/addons.xml.md5</checksum>
                <datadir zip="true">https://khoatdvo.github.io/kodirepo/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Add-on repository for khoatdvo</summary>
            <description lang="en_GB">Hosts the Home Media (Fshare) and VietmediaF 2 add-ons and their updates.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>
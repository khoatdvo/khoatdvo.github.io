<?xml version="1.0" encoding="UTF-8" standalone="yes"?>
<addons>
    <addon id="plugin.video.homemedia" name="Home Media" version="0.2.0" provider-name="khoatdvo">
        <requires>
            <import addon="xbmc.python" version="3.0.0" />
        </requires>
        <extension point="xbmc.python.pluginsource" library="main.py">
            <provides>video</provides>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Browse and play your Fshare.vn favorites</summary>
            <description lang="en_GB">A Kodi video add-on that logs in to your Fshare.vn account and lists your favorite bookmarks for streaming. Enter your Fshare email and password in the add-on settings.</description>
            <platform>all</platform>
            <license>Apache-2.0</license>
            <source>https://github.com/khoatdvo/home-media</source>
            <assets>
                <icon>resources/icon.png</icon>
                <fanart>resources/fanart.png</fanart>
            </assets>
            <news>v0.2.0 - Fshare.vn login and favorites listing.</news>
        </extension>
    </addon>
    <addon id="repository.khoatdvo" name="Khoa's Kodi Repository" version="1.0.0" provider-name="khoatdvo">
        <extension point="xbmc.addon.repository" name="Khoa's Kodi Repository">
            <dir>
                <info compressed="false">https://khoatdvo.github.io/kodirepo/addons.xml</info>
                <checksum>https://khoatdvo.github.io/kodirepo/addons.xml.md5</checksum>
                <datadir zip="true">https://khoatdvo.github.io/kodirepo/</datadir>
            </dir>
        </extension>
        <extension point="xbmc.addon.metadata">
            <summary lang="en_GB">Add-on repository for khoatdvo</summary>
            <description lang="en_GB">Hosts the Home Media (Fshare) add-on and its updates.</description>
            <platform>all</platform>
        </extension>
    </addon>
</addons>